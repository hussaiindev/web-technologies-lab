<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Form</title>
</head>
<body>

<form>
    Username:
    <input type="text" name="username"> <br><br>

    Password:
    <input type="password" name="password"> <br><br>

    Email:
    <input type="email" name="email"> <br><br>

    Gender:
    <input type="radio" name="gender" value="male"> Male
    <input type="radio" name="gender" value="female"> Female <br><br>

    DOB:
    <input type="date" name="dob"> <br><br>

    Address:
    <input type="text" name="address"> <br><br>

    Degree:
    <input type="radio" name="degree" value="cs"> CS
    <input type="radio" name="degree" value="se"> SE <br><br>

    Courses:
    <input type="checkbox" name="course" value="ai"> AI
    <input type="checkbox" name="course" value="se"> SE
    <input type="checkbox" name="course" value="os"> OS
    <input type="checkbox" name="course" value="ml"> ML <br><br>

    Total Credit Hours:
    <input type="text" value="12" readonly> <br><br>

    <input type="submit" value="Submit">
</form>

</body>
</html>

